<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="6dp">


    <!-- ئایکۆنی قورئان -->
    <!-- FIX 1: margin لای راست و چەپ زیاد کرا تا بلکێت بە corner radius ی widget_bg -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/widget_card_bg"
        android:paddingTop="0dp"
        android:paddingBottom="1dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="4dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp">

        <TextView
            android:id="@+id/btn_quran"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📖  قورئانی پیرۆز"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="4dp"
            android:clickable="true" />

    </LinearLayout>


    <!-- پێنج کاتی بانگ -->
    <!-- FIX 3: arch_section بە minHeight دابەزێنرا، slot height="match_parent" کرا تا لە هەموو مۆبایلێک یەکسان بێت -->
    <LinearLayout
        android:id="@+id/arch_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="52dp"
        android:orientation="horizontal"
        android:background="@drawable/widget_arch_bg"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:paddingStart="1dp"
        android:paddingEnd="1dp"
        android:gravity="center_vertical"
        android:layoutDirection="rtl">

        <!-- خەوتنان -->
        <LinearLayout
            android:id="@+id/slot_isha"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">
            <TextView
                android:id="@+id/lbl_isha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="خەوتنان"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="none" />
            <TextView
                android:id="@+id/time_isha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٩:١٠"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- ئێوارە -->
        <LinearLayout
            android:id="@+id/slot_maghrib"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">
            <TextView
                android:id="@+id/lbl_maghrib"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ئێوارە"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="none" />
            <TextView
                android:id="@+id/time_maghrib"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٧:٢٢"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- عەسر -->
        <LinearLayout
            android:id="@+id/slot_asr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">
            <TextView
                android:id="@+id/lbl_asr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عەسر"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="none" />
            <TextView
                android:id="@+id/time_asr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٤:٠٥"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- نیوەڕۆ -->
        <LinearLayout
            android:id="@+id/slot_dhuhr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">
            <TextView
                android:id="@+id/lbl_dhuhr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="نیوەڕۆ"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="none" />
            <TextView
                android:id="@+id/time_dhuhr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="١٢:٣٠"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- بەیانی -->
        <LinearLayout
            android:id="@+id/slot_fajr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">
            <TextView
                android:id="@+id/lbl_fajr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="بەیانی"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="none" />
            <TextView
                android:id="@+id/time_fajr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٣:٤٢"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="1dp" />
        </LinearLayout>
    </LinearLayout>


    <!-- قوبەی بەروارەکان -->
    <!-- FIX 1 + FIX 2: margin لای راست و چەپ و سەرەوە زیاد کرا -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/widget_card_bg"
        android:paddingTop="1dp"
        android:paddingBottom="0dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="1dp"
        android:layout_marginStart="1dp"
        android:layout_marginEnd="1dp">

        <TextView
            android:id="@+id/txt_hijri"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" ١٥ ذو الحجة ١٤٤٦"
            android:textColor="#FFD700"
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="none" />

        <TextView
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="#52FFFFFF"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/txt_gregorian"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" ٢٠٢٥/٠٦/١٣"
            android:textColor="#64B5F6"
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="none" />

        <TextView
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="#52FFFFFF"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/txt_kurdish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" ٢٣ گەلاوێژ"
            android:textColor="#81C784"
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="none" />

    </LinearLayout>


</LinearLayout>