<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="6dp">

    <!-- قوبەی بەروارەکان — لەسەرەوەی کاتەکانی بانگ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/widget_card_bg"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/txt_hijri"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="هـ ١٥ ذو الحجة ١٤٤٦"
            android:textColor="#FFD700"
            android:textSize="8sp"
            android:gravity="center"
            android:singleLine="true" />

        <View
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="#44FFFFFF"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/txt_gregorian"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="م ٢٠٢٥/٠٦/١٣"
            android:textColor="#64B5F6"
            android:textSize="8sp"
            android:gravity="center"
            android:singleLine="true" />

        <View
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="#44FFFFFF"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/txt_kurdish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ک ٢٣ گەلاوێژ"
            android:textColor="#81C784"
            android:textSize="8sp"
            android:gravity="center"
            android:singleLine="true" />

    </LinearLayout>

    <!-- پێنج کاتی بانگ — ئاسۆیی -->
    <LinearLayout
        android:id="@+id/arch_section"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:background="@drawable/widget_arch_bg"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- بەیانی -->
        <LinearLayout
            android:id="@+id/slot_fajr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp">
            <TextView
                android:id="@+id/lbl_fajr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="بەیانی"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/time_fajr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٣:٤٢"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- خۆرهەڵاتن -->
        <LinearLayout
            android:id="@+id/slot_sunrise"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp">
            <TextView
                android:id="@+id/lbl_sunrise"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="خۆرهەڵاتن"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/time_sunrise"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٥:١٠"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- نیوەڕۆ -->
        <LinearLayout
            android:id="@+id/slot_dhuhr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp">
            <TextView
                android:id="@+id/lbl_dhuhr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="نیوەڕۆ"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/time_dhuhr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="١٢:٣٠"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- عەسر -->
        <LinearLayout
            android:id="@+id/slot_asr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp">
            <TextView
                android:id="@+id/lbl_asr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عەسر"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/time_asr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٤:٠٥"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- ئێوارە -->
        <LinearLayout
            android:id="@+id/slot_maghrib"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp">
            <TextView
                android:id="@+id/lbl_maghrib"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ئێوارە"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/time_maghrib"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٧:٢٢"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- خەوتنان -->
        <LinearLayout
            android:id="@+id/slot_isha"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="3dp">
            <TextView
                android:id="@+id/lbl_isha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="خەوتنان"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/time_isha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٩:١٠"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ئایکۆنی قورئان — ئاسۆیی لەژێر کاتەکان -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/widget_card_bg"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/btn_quran"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📖  قورئانی پیرۆز"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:gravity="center"
            android:padding="7dp"
            android:clickable="true" />

    </LinearLayout>

</LinearLayout>